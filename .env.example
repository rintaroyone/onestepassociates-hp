# Resend email delivery for the contact form.
# Copy this file to `.env.local` and fill in real values. Never commit secrets.

# API key from the Resend dashboard (https://resend.com/api-keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where inquiries are delivered. Comma-separate to send to multiple recipients,
# e.g. CONTACT_TO_EMAIL=alice@example.com,bob@example.com
CONTACT_TO_EMAIL=contact@example.com

# The "From" address. Must be on a domain verified in Resend.
CONTACT_FROM_EMAIL=OneStep Associates <noreply@your-verified-domain.com>
